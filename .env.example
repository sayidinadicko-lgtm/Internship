# ── Instagram credentials ────────────────────────────────────────────────────
INSTAGRAM_USERNAME=ledeclicmental
INSTAGRAM_PASSWORD=your_instagram_password_here

# ── Anthropic / Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Posting schedule (HH:MM, Paris time, 3 entries) ─────────────────────────
POST_TIMES=07:00,12:30,19:00
TIMEZONE=Europe/Paris

# ── Claude model ─────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6

# ── Paths ────────────────────────────────────────────────────────────────────
INSTAGRAM_SESSION_FILE=data/session/instagram_session.json
POST_HISTORY_FILE=data/post_history.json

# ── Safety ───────────────────────────────────────────────────────────────────
# Set to true to run full pipeline without posting to Instagram
DRY_RUN=false

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
